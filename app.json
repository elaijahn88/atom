{
  "expo": {
    "name": "jovan",
    "slug": "jovan",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./icon.png",
    "scheme": "elijah",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "bundleIdentifier": "com.xlijah.jovan",
      "buildNumber": "1.0.0",
      "supportsTablet": true,
      "infoPlist": {
        "UIBackgroundModes": ["fetch", "remote-notification"],
        "NSUserTrackingUsageDescription": "This identifier will be used to deliver personalized ads.",
        "CFBundleShortVersionString": "1.0.0"
      }
    },
    "android": {
      "package": "com.xlijah.Atom",
      "adaptiveIcon": {
        "backgroundColor": "#000000",
        "foregroundImage": "./android-icon-foreground.png.png",
        "backgroundImage": "./android-icon-background.png.png",
        "monochromeImage": "./android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./splash-icon.png",
          "imageWidth": 50,
          "resizeMode": "contain",
          "backgroundColor": "#000000",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./icon.png",
          "color": "#ffffff",
          "sounds": true
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "eas": {
        "projectId": "f0394be7-a4ad-43a1-a13c-9a486537658e"
      }
    },
    "updates": {
      "fallbackToCacheTimeout": 0
    },
    "runtimeVersion": {
      "policy": "appVersion"
    }
  }
}
