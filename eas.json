{
  "cli": {
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "distribution": "internal",
      "ios": {
        "simulator": true,
        "buildType": "simulator",
        "autoIncrement": true
      }
    },
    "preview": {
      "distribution": "internal",
      "ios": {
        "simulator": false,
        "buildType": "adhoc",
        "autoIncrement": true
      }
    },
    "production": {
      "distribution": "internal",
      "ios": {
        "simulator": false,
        "buildType": "release",
        "autoIncrement": true
      }
    }
  }
}
